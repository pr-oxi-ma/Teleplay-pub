# TelePlay frontend config
# Optional. If missing, the frontend calls same-origin /api.

# Backend origin, with or without /api. Examples:
# VITE_API_BASE_URL=https://your-backend.example.com
# VITE_API_BASE_URL=https://your-backend.example.com/api

VITE_API_BASE_URL=http://localhost:5001

# Vite dev server only
VITE_DEV_SERVER_PORT=5000
VITE_ALLOWED_HOSTS=localhost

# Web auth now uses HttpOnly cookies. For different frontend/backend origins,
# set backend WEB_BASE_URL to this frontend origin. Cookie Secure and
# CORS are auto-derived there. Axios sends credentials via withCredentials=true.
