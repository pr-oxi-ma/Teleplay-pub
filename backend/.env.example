# =========================================
# TelePlay - Backend Configuration
# =========================================

# -----------------------------------------
# TELEGRAM CONFIGURATION
# -----------------------------------------
# Get API ID and Hash from https://my.telegram.org
TELEGRAM_API_ID=your_api_id
TELEGRAM_API_HASH=your_api_hash

# Create a bot via @BotFather and get the token
TELEGRAM_BOT_TOKEN=your_bot_token

# Optional helper bots for faster download speeds (comma-separated tokens)
# IMPORTANT: All helper bots MUST be added as Administrators to your Storage Channel!
TELEGRAM_HELPER_BOT_TOKENS=
TELEGRAM_CLIENT_CONCURRENCY=3

# Create a private channel, add your bot as admin, and get the channel ID
# Channel IDs start with -100 (e.g., -1001234567890)
TELEGRAM_STORAGE_CHANNEL_ID=-100xxxxxxxxxx

# Optional comma-separated Telegram IDs of authorized users.
# Leave empty to allow everyone to use the bot.
AUTH_USERS=

# -----------------------------------------
# SECURITY
# -----------------------------------------
JWT_SECRET=your-super-secret-key-change-in-production
JWT_EXPIRY_MINUTES=10080
JWT_REFRESH_EXPIRY_DAYS=90

# Web HttpOnly cookie session settings
# CORS origin and cookie Secure are auto-derived from WEB_BASE_URL. Cookie Domain is omitted by default (host-only backend cookie).
# If your frontend/API are on different parent domains, set SESSION_COOKIE_SAMESITE=none.
SESSION_ACCESS_COOKIE_NAME=tp_access
SESSION_REFRESH_COOKIE_NAME=tp_refresh
SESSION_COOKIE_SAMESITE=lax
SESSION_CSRF_ENABLED=true

# Auth session DB cleanup / anti-bloat
# Keeps abandoned incognito/browser sessions from piling up forever.
AUTH_SESSION_CLEANUP_ENABLED=true
AUTH_SESSION_MAX_ACTIVE_PER_USER=10
AUTH_SESSION_INACTIVE_DAYS=14
AUTH_SESSION_REVOKED_RETENTION_DAYS=7

# -----------------------------------------
# DATABASE
# -----------------------------------------
# PostgreSQL (recommended for production)
DATABASE_URL=postgresql://postgres:password@localhost:5432/teleplay

# SQLite (no PostgreSQL setup needed — great for small/local deployments)
# DATABASE_URL=sqlite:///./data/teleplay.db


# -----------------------------------------
# OPTIONAL REDIS CACHE / PREFETCH
# -----------------------------------------
# Leave REDIS_URL empty to run without Redis.
REDIS_URL=

# Cache only the first tiny stream chunks. Never cache full videos.
REDIS_CACHE_STREAM_CHUNKS=true
REDIS_STREAM_CHUNK_CACHE_CHUNKS=2
REDIS_STREAM_CHUNK_TTL_SECONDS=300

# Best-effort previous/next media warmup. Requires REDIS_URL.
REDIS_PREFETCH_ENABLED=true
REDIS_PREFETCH_CHUNK_COUNT=2

# Local docker-compose optional Redis service limit. Used only with: docker compose --profile redis up -d
REDIS_MAXMEMORY=64mb

# -----------------------------------------
# SERVER
# -----------------------------------------
SERVER_HOST=0.0.0.0
SERVER_PORT=5001
LOGIN_CODE_LENGTH=6
LOGIN_CODE_EXPIRY_MINUTES=5
WEB_LOGIN_CODE_LENGTH=32

# -----------------------------------------
# WEB / CORS
# -----------------------------------------
# Public URL where the web app is accessible. Used for bot one-time login links.
WEB_BASE_URL=https://your-frontend.example.com

# Backend CORS origin is auto-derived from WEB_BASE_URL.

# On-demand image thumbnails (only generated WebP files are retained)
THUMBNAIL_CACHE_DIR=
THUMBNAIL_MAX_DIMENSION=320
THUMBNAIL_WEBP_QUALITY=68
THUMBNAIL_GENERATION_CONCURRENCY=2

# -----------------------------------------
# PRODUCTION HYBRID MEDIA CACHE (Optional)
# -----------------------------------------
# off | gdrive | cloudflare | hybrid
CACHE_MODE=off
MEDIA_CACHE_KEY_VERSION=2

# Google Drive encrypted L2 cache
GOOGLE_DRIVE_CLIENT_ID=
GOOGLE_DRIVE_CLIENT_SECRET=
GOOGLE_DRIVE_REFRESH_TOKEN=
GOOGLE_DRIVE_CACHE_FOLDER_ID=
# Required for gdrive/hybrid. Generate once and never rotate casually:
# python -c "import os,base64; print(base64.b64encode(os.urandom(32)).decode())"
MEDIA_CACHE_MASTER_KEY_BASE64=

# Only the two most useful policy overrides are shown. All other cache tuning
# values have production-safe defaults in app/config.py.
GDRIVE_CACHE_BUDGET_GB=4000
GDRIVE_MAX_CACHE_FILE_GB=5

# Cloudflare Worker plaintext L1 cache. This must be an absolute origin with
# https:// and no path. Examples:
#   https://your-worker.your-subdomain.workers.dev
#   https://l1-media.example.com
CLOUDFLARE_WORKER_BASE_URL=
CLOUDFLARE_EDGE_SIGNING_SECRET=
CLOUDFLARE_ORIGIN_SECRET=
CLOUDFLARE_TOUCH_SECRET=

# Public readable /api/stream/s/... behavior:
# off      = direct backend stream (Drive/Telegram; no L1 on public link)
# redirect = always issue a temporary 307 to the signed Worker URL; the Worker
#            serves L1 on HIT and fills L1 from Drive/Telegram on MISS
# proxy    = keep the same public URL and use L1 through a Worker Route
PUBLIC_STREAM_EDGE_MODE=off

# Recommended clean-domain redirect profile:
# CLOUDFLARE_WORKER_BASE_URL=https://l1-media.example.com
# PUBLIC_STREAM_EDGE_MODE=redirect
